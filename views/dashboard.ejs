<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Dashboard - GambitCore</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@500;700;900&family=Nunito:wght@400;600;700&display=swap" rel="stylesheet">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    
    <style>
        /* --- GAMBITCORE OFFICIAL THEME VARIABLES --- */
        :root {
            --bg: #1a1a1a;          /* Deep warm gray */
            --card-bg: #262421;     /* Surface gray */
            --card-inner: #1e1c1a;  /* Inset gray */
            --border: #3c3a38;      /* Subtle divider */
            --accent: #81b64c;      /* Chess.com/Gambit Green */
            --accent-hover: #92c95e;
            --accent-glow: rgba(129, 182, 76, 0.25);
            --text-main: #ffffff;
            --text-muted: #aaa;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            background-color: var(--bg); color: var(--text-main);
            font-family: 'Nunito', sans-serif; overflow-x: hidden;
            background-image: radial-gradient(circle at 50% 0%, #2a2a2a 0%, #1a1a1a 70%);
            min-height: 100vh;
        }

        /* --- GLASSMORPHISM NAVBAR --- */
        .glass-nav {
            position: fixed; top: 0; left: 0; width: 100%; z-index: 1000;
            display: flex; justify-content: space-between; align-items: center;
            padding: 16px 40px;
            background: rgba(26, 26, 26, 0.7);
            backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
            border-bottom: 1px solid var(--border);
        }
        
        .logo {
            font-family: 'Montserrat', sans-serif; font-size: 1.6rem; font-weight: 900;
            color: white; text-decoration: none; display: flex; align-items: center; gap: 8px;
        }
        .logo-icon { color: var(--accent); font-size: 2rem; }
        
        .nav-actions { display: flex; gap: 20px; align-items: center; }
        .nav-link {
            color: var(--text-muted); text-decoration: none; font-weight: 700;
            transition: color 0.2s; font-size: 1.05rem;
        }
        .nav-link:hover { color: white; }
        .logout-btn {
            color: #ef4444; background: rgba(239, 68, 68, 0.1);
            padding: 8px 16px; border-radius: 8px; font-weight: 700;
            text-decoration: none; transition: all 0.2s; border: 1px solid transparent;
        }
        .logout-btn:hover { background: rgba(239, 68, 68, 0.15); border-color: rgba(239, 68, 68, 0.3); }

        /* --- BENTO BOX GRID LAYOUT --- */
        .dashboard-wrapper {
            max-width: 1200px; margin: 110px auto 40px; padding: 0 20px;
            display: grid; grid-template-columns: repeat(12, 1fr);
            grid-auto-rows: minmax(200px, auto); gap: 24px;
        }

        .bento-card {
            background: var(--card-bg); border: 1px solid var(--border);
            border-radius: 20px; padding: 32px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.3);
            position: relative; overflow: hidden;
            display: flex; flex-direction: column;
        }

        /* 1. HERO / PLAY CARD */
        .card-play { grid-column: span 8; justify-content: center; background: linear-gradient(135deg, #262421 0%, #1a1a1a 100%); }
        .hero-tag { display: inline-block; padding: 6px 12px; background: rgba(129, 182, 76, 0.15); color: var(--accent); border-radius: 20px; font-size: 0.85rem; font-weight: 800; letter-spacing: 1px; margin-bottom: 16px; text-transform: uppercase; }
        .hero-title { font-family: 'Montserrat', sans-serif; font-size: 3.5rem; font-weight: 900; line-height: 1.1; margin-bottom: 16px; letter-spacing: -1px; }
        .btn-glow {
            display: inline-flex; align-items: center; justify-content: center; gap: 10px;
            background: var(--accent); color: white; font-family: 'Montserrat', sans-serif; font-weight: 900;
            font-size: 1.2rem; padding: 18px 40px; border-radius: 12px; text-decoration: none;
            box-shadow: 0 6px 0 #537a31; transition: all 0.1s; border: none; cursor: pointer; width: fit-content;
        }
        .btn-glow:active { transform: translateY(6px); box-shadow: 0 0px 0 #537a31; }

        /* 2. PROFILE CARD */
        .card-profile { grid-column: span 4; align-items: center; text-align: center; }
        .profile-avatar {
            width: 80px; height: 80px; background: var(--card-inner); border: 2px solid #555;
            border-radius: 50%; display: flex; align-items: center; justify-content: center;
            font-size: 45px; margin-bottom: 16px; box-shadow: 0 4px 15px rgba(0,0,0,0.4);
        }
        .profile-name { font-family: 'Montserrat', sans-serif; font-size: 1.6rem; font-weight: 800; margin-bottom: 24px; display: flex; align-items: center; justify-content: center; }
        .stat-group { display: flex; width: 100%; gap: 12px; }
        .stat-item { flex: 1; background: var(--card-inner); padding: 16px; border-radius: 12px; border: 1px solid var(--border); }
        .stat-value { font-family: 'Montserrat', sans-serif; font-size: 1.8rem; font-weight: 900; color: var(--accent); }
        .stat-label { font-size: 0.8rem; color: var(--text-muted); text-transform: uppercase; font-weight: 700; margin-top: 4px; letter-spacing: 1px; }

        /* 3. LEADERBOARD CARD */
        .card-leaderboard { grid-column: span 7; }
        .section-title { font-family: 'Montserrat', sans-serif; font-size: 1.3rem; font-weight: 800; margin-bottom: 20px; display: flex; justify-content: space-between; }
        .lb-row {
            display: flex; align-items: center; padding: 14px 16px; background: var(--card-inner);
            border-radius: 10px; margin-bottom: 8px; transition: transform 0.2s; border: 1px solid transparent;
        }
        .lb-row:hover { transform: translateX(5px); border-color: var(--border); }
        .lb-rank { width: 40px; font-weight: 900; font-size: 1.1rem; color: var(--text-muted); }
        .lb-rank.gold { color: #f1c40f; text-shadow: 0 0 10px rgba(241,196,15,0.4); }
        .lb-rank.silver { color: #bdc3c7; }
        .lb-rank.bronze { color: #d35400; }
        .lb-user { flex: 1; font-weight: 700; font-size: 1.05rem; }
        .lb-elo { font-family: 'Montserrat', sans-serif; font-weight: 800; color: var(--accent); }

        /* 4. EVAL INFO CARD */
        .card-info { grid-column: span 5; background: linear-gradient(135deg, rgba(129,182,76,0.05) 0%, transparent 100%); }
        .tech-badge { display: inline-flex; align-items: center; gap: 8px; padding: 8px 14px; background: var(--card-inner); border: 1px solid var(--border); border-radius: 10px; font-size: 0.9rem; font-weight: 700; margin: 0 8px 8px 0; }
        .tech-badge span { color: var(--accent); }

        /* --- MODAL SPECIFIC CSS ADDED --- */
        .btn-modern {
            background: var(--card-inner); color: var(--text-main); border: 1px solid var(--border);
            padding: 12px; border-radius: 10px; font-weight: 800; font-family: 'Montserrat';
            cursor: pointer; transition: 0.2s; display: flex; justify-content: center; align-items: center; gap: 8px;
        }
        .btn-modern:hover { background: #333; }
        
        .join-input {
            background: #111; border: 1px solid var(--border); color: white; padding: 15px; 
            border-radius: 10px; width: 100%; text-align: center; 
            font-family: 'Nunito', sans-serif; font-size: 1.1rem; 
            margin-bottom: 15px; transition: border 0.2s; outline: none;
        }
        .join-input:focus { border-color: var(--accent); }

        /* --- RESPONSIVE GRID --- */
        @media (max-width: 1024px) {
            .card-play { grid-column: span 12; }
            .card-profile { grid-column: span 12; flex-direction: row; text-align: left; align-items: center; justify-content: space-between; }
            .profile-avatar { margin-bottom: 0; margin-right: 20px; }
            .stat-group { width: auto; min-width: 300px; }
            .card-leaderboard { grid-column: span 12; }
            .card-info { grid-column: span 12; }
        }
        @media (max-width: 640px) {
            .card-profile { flex-direction: column; text-align: center; }
            .profile-avatar { margin-right: 0; margin-bottom: 16px; }
            .stat-group { flex-direction: column; min-width: 100%; }
            .glass-nav { padding: 16px 20px; }
            .hero-title { font-size: 2.5rem; }
            .nav-actions { gap: 10px; }
        }
    </style>
</head>
<body>

    <nav class="glass-nav gsap-nav">
        <a href="/" class="logo">
            <span class="logo-icon">♚</span> 
            GambitCore
        </a>
        <div class="nav-actions">
            <a href="/" class="nav-link">Home</a>
            <a href="/logout" class="logout-btn">Logout</a>
        </div>
    </nav>

    <main class="dashboard-wrapper">
        
        <div class="bento-card card-play gsap-bento">
            <div style="position: relative; z-index: 2;">
                <div class="hero-tag">Ranked Matchmaking</div>
                <h1 class="hero-title">Your Next Move<br>Awaits.</h1>
                <p style="color: var(--text-muted); font-size: 1.1rem; margin-bottom: 32px; max-width: 400px; font-weight: 600;">
                    Enter the matchmaking queue or challenge a friend in a private room.
                </p>
                <button class="btn-glow" onclick="window.location.href='/matchmaking'">
                    <span>♟</span> Play Chess
                </button>
            </div>
            <div style="position: absolute; right: -20px; bottom: -60px; font-size: 16rem; color: rgba(255,255,255,0.02); transform: rotate(-15deg); pointer-events: none; user-select: none;">♞</div>
        </div>

        <div class="bento-card card-profile gsap-bento">
            <div style="display: flex; flex-direction: column; align-items: center;">
                <div class="profile-avatar">♔</div>
                <div class="profile-name">
                    <%= username %> 
                    <span onclick="openEditModal()" style="cursor:pointer; font-size: 1.2rem; margin-left:12px; opacity:0.6; transition: 0.2s;" onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.6'">✏️</span>
                </div>
            </div>
            <div class="stat-group">
                <div class="stat-item">
                    <div class="stat-value" id="count-elo">0</div>
                    <div class="stat-label">Blitz Elo</div>
                </div>
                <div class="stat-item">
                    <div class="stat-value" id="count-games" style="color: #f39c12;">0</div>
                    <div class="stat-label">Matches</div>
                </div>
            </div>
        </div>

        <div class="bento-card card-leaderboard gsap-bento">
            <div class="section-title">
                Global Top Rated
                <span style="color: var(--text-muted); font-size: 0.9rem; font-weight: 600; text-transform: uppercase;">Live Updates</span>
            </div>
            <div class="lb-container">
                <% if (topPlayers && topPlayers.length > 0) { %>
                    <% topPlayers.forEach(function(player, index) { %>
                        <div class="lb-row gsap-lb-item">
                            <div class="lb-rank <%= index === 0 ? 'gold' : index === 1 ? 'silver' : index === 2 ? 'bronze' : '' %>">
                                #<%= index + 1 %>
                            </div>
                            <div class="lb-user"><%= player.username %></div>
                            <div class="lb-elo"><%= player.rating %></div>
                        </div>
                    <% }); %>
                <% } else { %>
                    <p style="color: var(--text-muted); text-align: center; padding: 20px; font-weight: 600;">No ranked players found.</p>
                <% } %>
            </div>
        </div>

        <div class="bento-card card-info gsap-bento">
            <div class="section-title">Evaluation II Status <span style="color: var(--accent);">Active</span></div>
            <p style="color: var(--text-muted); line-height: 1.6; margin-bottom: 24px; font-weight: 600;">
                This dashboard is securely rendered Server-Side via Node.js & EJS. Real-time data is actively pulled from MongoDB Atlas.
            </p>
            <div>
                <div class="tech-badge"><span>●</span> SSR Architecture</div>
                <div class="tech-badge"><span>●</span> JWT Auth</div>
                <div class="tech-badge"><span>●</span> WebSockets</div>
                <div class="tech-badge"><span>●</span> MongoDB</div>
            </div>
        </div>

    </main>

    <div class="modal-overlay hidden" id="edit-modal" style="position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.8); backdrop-filter:blur(8px); display:none; justify-content:center; align-items:center; z-index:2000;">
        <div class="bento-card" id="edit-modal-card" style="width:90%; max-width:400px; text-align:center;">
            <h2 style="font-family:'Montserrat'; margin-bottom:10px;">Change Username</h2>
            <p style="color: var(--text-muted); margin-bottom: 20px; font-size: 0.9rem;">Must be at least 3 characters.</p>
            <input type="text" id="new-name-input" class="join-input" placeholder="Enter new name" value="<%= username %>">
            <div style="display:flex; gap:10px;">
                <button class="btn-glow" id="btn-save-name" onclick="submitNameChange()" style="flex:1; padding:12px; font-size:1.1rem; border-radius:10px; box-shadow: 0 4px 0 #537a31;">Save</button>
                <button class="btn-modern" onclick="closeEditModal()" style="flex:1;">Cancel</button>
            </div>
        </div>
    </div>

    <script>
        // Safely parse EJS variables to prevent NaN crashes
        const targetElo = parseInt("<%= rating || 0 %>", 10);
        const targetGames = parseInt("<%= gamesPlayed || 0 %>", 10);

        document.addEventListener("DOMContentLoaded", () => {
            // 1. Drop down the glass navbar
            gsap.from(".gsap-nav", { y: -100, opacity: 0, duration: 1, ease: "power4.out" });

            // 2. Bento cards pop in using stagger
            gsap.from(".gsap-bento", { 
                y: 40, opacity: 0, scale: 0.95, 
                duration: 0.8, stagger: 0.15, 
                ease: "back.out(1.2)", delay: 0.2 
            });

            // 3. Leaderboard rows slide in
            gsap.from(".gsap-lb-item", { 
                x: -20, opacity: 0, 
                duration: 0.5, stagger: 0.1, 
                ease: "power2.out", delay: 0.7 
            });

            // 4. Number Counters
            gsap.to("#count-elo", { 
                textContent: targetElo, duration: 2, 
                ease: "power3.out", snap: { textContent: 1 }, delay: 0.6 
            });
            gsap.to("#count-games", { 
                textContent: targetGames, duration: 2, 
                ease: "power3.out", snap: { textContent: 1 }, delay: 0.6 
            });
        });

        // --- EDIT MODAL JAVASCRIPT LOGIC ---
        function openEditModal() {
            const modal = document.getElementById('edit-modal');
            const card = document.getElementById('edit-modal-card');
            modal.style.display = 'flex';
            gsap.fromTo(modal, {opacity: 0}, {opacity: 1, duration: 0.2});
            gsap.fromTo(card, {scale: 0.8, y: 20}, {scale: 1, y: 0, duration: 0.4, ease: "back.out(1.2)"});
        }

        function closeEditModal() {
            const modal = document.getElementById('edit-modal');
            gsap.to(modal, {opacity: 0, duration: 0.2, onComplete: () => {
                modal.style.display = 'none';
            }});
        }

        async function submitNameChange() {
            const newName = document.getElementById('new-name-input').value.trim();
            const btn = document.getElementById('btn-save-name');
            
            if (newName.length < 3) {
                alert("Name must be at least 3 characters.");
                return;
            }

            const originalText = btn.innerText;
            btn.innerText = "Saving...";

            try {
                const response = await fetch('/api/user/update-name', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ newUsername: newName })
                });

                const data = await response.json();
                
                if (data.status === 'success') {
                    // Success! Refresh the page to reflect the new name in the UI and Navbar
                    window.location.reload();
                } else {
                    alert(data.message || 'Could not update name.');
                    btn.innerText = originalText;
                }
            } catch (err) {
                alert('Server error. Ensure your backend route is set up!');
                btn.innerText = originalText;
            }
        }
    </script>
</body>
</html>