<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>GambitCore - Multiplayer Chess</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@500;800;900&family=Nunito:wght@400;600;700&display=swap" rel="stylesheet">
    
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>
    
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            background-color: #1a1a1a; color: #ffffff;
            font-family: 'Nunito', sans-serif; overflow-x: hidden;
            background-image: radial-gradient(circle at 50% 0%, #2a2a2a 0%, #1a1a1a 70%);
        }

        /* --- NAVBAR --- */
        nav {
            display: flex; justify-content: space-between; align-items: center;
            padding: 25px 50px; position: absolute; top: 0; width: 100%; z-index: 10;
        }
        .logo { font-family: 'Montserrat', sans-serif; font-size: 2rem; font-weight: 900; letter-spacing: -1px; text-decoration: none; color: white; }
        .logo span { color: #81b64c; }
        .auth-btns { display: flex; gap: 15px; align-items: center; }
        .btn {
            padding: 10px 24px; font-family: 'Montserrat', sans-serif; font-weight: 800; font-size: 1rem;
            border-radius: 8px; cursor: pointer; transition: all 0.2s; border: none; text-decoration: none;
        }
        .btn-login { background: transparent; color: #fff; border: 2px solid #444; }
        .btn-login:hover { border-color: #81b64c; color: #81b64c; }
        .btn-register { background: #81b64c; color: white; box-shadow: 0 4px 0 #537a31; }
        .btn-register:hover { transform: translateY(2px); box-shadow: 0 2px 0 #537a31; }

        /* --- HERO SECTION --- */
        .hero {
            min-height: 100vh; display: flex; flex-direction: column; justify-content: center; align-items: center;
            text-align: center; position: relative; padding: 0 20px;
        }
        .hero-title {
            font-family: 'Montserrat', sans-serif; font-size: 5.5rem; font-weight: 900; line-height: 1.1; margin-bottom: 20px;
            background: linear-gradient(to right, #ffffff, #a0a0a0); -webkit-background-clip: text; -webkit-text-fill-color: transparent;
        }
        .hero-sub { font-size: 1.4rem; color: #aaa; max-width: 600px; margin-bottom: 40px; }
        .hero-cta { padding: 18px 45px; font-size: 1.3rem; border-radius: 12px; display: inline-block; }

        .floating-piece {
            position: absolute; font-size: 6rem; color: rgba(255,255,255,0.03); z-index: -1;
            user-select: none; pointer-events: none;
        }

        /* --- SYLLABUS FEATURES --- */
        .section-padding { padding: 100px 30px; max-width: 1200px; margin: 0 auto; }
        .section-header { font-family: 'Montserrat', sans-serif; font-size: 3rem; font-weight: 900; text-align: center; margin-bottom: 60px; color: #fff; }
        .section-header span { color: #81b64c; }
        
        .features { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 30px; }
        .feature-card {
            background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05);
            padding: 40px; border-radius: 16px; backdrop-filter: blur(10px);
            transition: transform 0.3s, border-color 0.3s;
        }
        .feature-card:hover { transform: translateY(-10px); border-color: #81b64c; background: rgba(255,255,255,0.04); }
        .f-icon { font-size: 3rem; margin-bottom: 20px; }
        .f-title { font-family: 'Montserrat', sans-serif; font-size: 1.5rem; font-weight: 800; margin-bottom: 10px; color: #fff; }
        .f-text { color: #888; line-height: 1.6; }

        /* --- TECH STACK SECTION --- */
        .tech-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px; }
        .tech-item {
            background: #262421; padding: 30px; border-radius: 12px; text-align: center; border: 1px solid #3c3a38;
        }
        .tech-item h4 { font-family: 'Montserrat', sans-serif; font-size: 1.3rem; margin-bottom: 10px; color: #fff; }
        .tech-item p { color: #aaa; font-size: 0.95rem; }
        
        /* --- GLOBAL STATS SECTION --- */
        .stats-banner {
            background: linear-gradient(135deg, #1e1c1a 0%, #262421 100%);
            border-top: 1px solid #3c3a38; border-bottom: 1px solid #3c3a38;
            padding: 80px 30px; text-align: center; display: flex; justify-content: space-around; flex-wrap: wrap; gap: 40px;
        }
        .stat-block { flex: 1; min-width: 200px; }
        .stat-number { font-family: 'Montserrat', sans-serif; font-size: 4rem; font-weight: 900; color: #81b64c; margin-bottom: 10px; }
        .stat-label { font-size: 1.2rem; color: #aaa; font-weight: 700; text-transform: uppercase; letter-spacing: 2px; }

        footer { text-align: center; padding: 40px; color: #666; font-size: 0.9rem; border-top: 1px solid #222; margin-top: 50px; }

        /* --- AUTH MODAL --- */
        .modal-overlay {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.8); backdrop-filter: blur(8px);
            display: flex; justify-content: center; align-items: center;
            opacity: 0; pointer-events: none; transition: opacity 0.3s; z-index: 100;
        }
        .modal-overlay.active { opacity: 1; pointer-events: all; }
        .auth-box {
            background: #262421; border: 1px solid #3c3a38; padding: 40px; border-radius: 16px;
            width: 100%; max-width: 400px; box-shadow: 0 25px 50px rgba(0,0,0,0.5);
            transform: scale(0.95); transition: transform 0.3s; position: relative;
        }
        .modal-overlay.active .auth-box { transform: scale(1); }
        .auth-title { font-family: 'Montserrat', sans-serif; font-size: 2rem; font-weight: 800; text-align: center; margin-bottom: 25px; }
        .auth-input {
            width: 100%; padding: 15px; margin-bottom: 15px; background: #1e1c1a;
            border: 1px solid #444; color: white; border-radius: 8px; font-family: 'Nunito', sans-serif; font-size: 1.1rem;
        }
        .auth-input:focus { outline: none; border-color: #81b64c; }
        .auth-toggle { text-align: center; margin-top: 20px; color: #aaa; font-size: 0.9rem; }
        .auth-toggle span { color: #81b64c; cursor: pointer; font-weight: 700; }
        .error-msg { color: #ff4c4c; text-align: center; margin-bottom: 15px; display: none; font-weight: 700; }
        .close-btn { position: absolute; top: 15px; right: 20px; font-size: 1.5rem; cursor: pointer; color: #888; }
        .close-btn:hover { color: #fff; }

        /* ============================================================
           📱 MOBILE RESPONSIVENESS FIXES
           ============================================================ */
        @media (max-width: 768px) {
            /* 1. Navbar adjustments */
            nav {
                padding: 15px 20px;
                flex-direction: column; /* Stacks logo above buttons */
                gap: 15px;
            }
            .logo { font-size: 1.8rem; }
            .btn { padding: 8px 18px; font-size: 0.9rem; }

            /* 2. Hero Section scaling */
            .hero-title {
                font-size: 2.8rem; /* Scaled down from 5.5rem */
                margin-top: 80px;  /* Pushes text down so stacked nav doesn't cover it */
            }
            .hero-sub {
                font-size: 1.1rem;
                padding: 0 10px;
                margin-bottom: 30px;
            }
            .hero-cta { padding: 14px 30px; font-size: 1.1rem; }

            /* 3. Tame the floating chess pieces */
            .floating-piece {
                font-size: 3.5rem; /* Shrinks them so they don't block the screen */
                opacity: 0.02;     /* Dims them slightly more on mobile */
            }

            /* 4. Section & Typography adjustments */
            .section-padding { padding: 60px 20px; }
            .section-header { font-size: 2.2rem; margin-bottom: 40px; }
            
            /* 5. Stats Banner scaling */
            .stats-banner { padding: 50px 20px; gap: 30px; }
            .stat-number { font-size: 3rem; }
            
            /* 6. Auth Modal constraints */
            .auth-box {
                width: 90%;
                padding: 30px 20px;
            }
            .auth-title { font-size: 1.6rem; }
        }
    </style>
</head>
<body>

    <nav>
        <a href="/" class="logo">♚ Gambit<span>Core</span></a>
        <div class="auth-btns">
            <% if (locals.username) { %>
                <div style="color: #aaa; font-weight: 700; margin-right: 15px; display: flex; align-items: center; gap: 8px;">
                    <span style="color: #81b64c;">●</span> <%= username %>
                </div>
                <button class="btn btn-login" onclick="window.location.href='/dashboard'">Dashboard</button>
            <% } else { %>
                <button class="btn btn-login" onclick="openAuth('login')">Log In</button>
                <button class="btn btn-register" onclick="openAuth('register')">Sign Up</button>
            <% } %>
        </div>
    </nav>

    <div class="floating-piece" style="top: 15%; left: 10%;">♞</div>
    <div class="floating-piece" style="top: 60%; left: 5%;">♛</div>
    <div class="floating-piece" style="top: 20%; right: 12%;">♜</div>
    <div class="floating-piece" style="top: 70%; right: 8%;">♝</div>

    <section class="hero">
        <h1 class="hero-title gsap-hero">Master the<br>Digital Board.</h1>
        <p class="hero-sub gsap-hero">Experience real-time, authoritative multiplayer chess built from the ground up on Node.js and Socket.io.</p>
        
        <div class="gsap-hero">
            <% if (locals.username) { %>
                <button class="btn btn-register hero-cta" onclick="window.location.href='/matchmaking'">Play Now</button>
            <% } else { %>
                <button class="btn btn-register hero-cta" onclick="openAuth('login')">Play Now</button>
            <% } %>
        </div>
    </section>

    <section class="section-padding">
        <h2 class="section-header gsap-fade">Built for <span>Evaluation II</span></h2>
        <div class="features">
            <div class="feature-card gsap-fade-up">
                <div class="f-icon">⚡</div>
                <h3 class="f-title">Full-Duplex Sockets</h3>
                <p class="f-text">Powered by Socket.io for instantaneous bi-directional event transmission, guaranteeing zero-latency piece synchronization and live chat.</p>
            </div>
            <div class="feature-card gsap-fade-up">
                <div class="f-icon">🛡️</div>
                <h3 class="f-title">Authoritative Server</h3>
                <p class="f-text">The frontend is a dumb client. All legal moves, timer deductions, and checkmates are calculated strictly on the backend to prevent cheating.</p>
            </div>
            <div class="feature-card gsap-fade-up">
                <div class="f-icon">🗄️</div>
                <h3 class="f-title">MongoDB Matchmaking</h3>
                <p class="f-text">Secure JWT session cookies authenticate players against our MongoDB Atlas database, tracking global Elo ratings in real-time.</p>
            </div>
        </div>
    </section>

    <section class="section-padding" style="background: rgba(255,255,255,0.01);">
        <h2 class="section-header gsap-fade">The <span>Arsenal</span></h2>
        <div class="tech-grid">
            <div class="tech-item gsap-tech">
                <h4 style="color: #68a063;">Node.js</h4>
                <p>Non-blocking, event-driven JavaScript runtime powering our robust backend infrastructure.</p>
            </div>
            <div class="tech-item gsap-tech">
                <h4 style="color: #ffffff;">Express.js</h4>
                <p>Fast, unopinionated web framework handling our SSR EJS routing and JWT authentication middleware.</p>
            </div>
            <div class="tech-item gsap-tech">
                <h4 style="color: #47A248;">MongoDB Atlas</h4>
                <p>Cloud NoSQL database utilized alongside Mongoose ODM for scalable user profiling and Elo tracking.</p>
            </div>
            <div class="tech-item gsap-tech">
                <h4 style="color: #010101; background: #fff; display: inline-block; padding: 2px 8px; border-radius: 4px; margin-bottom: 10px;">Socket.io</h4>
                <p>Event-based real-time engine ensuring constant connection between our authoritative core and the chess canvas.</p>
            </div>
        </div>
    </section>

    <section class="stats-banner">
        <div class="stat-block">
            <div class="stat-number">2882</div>
            <div class="stat-label">Highest Elo</div>
        </div>
        <div class="stat-block">
            <div class="stat-number">10ms</div>
            <div class="stat-label">Socket Latency</div>
        </div>
        <div class="stat-block">
            <div class="stat-number">100%</div>
            <div class="stat-label">Cheat Proof</div>
        </div>
    </section>

    <footer>
        <p>&copy; 2026 GambitCore. Built for Evaluation II.</p>
    </footer>

    <div class="modal-overlay" id="auth-modal">
        <div class="auth-box">
            <div class="close-btn" onclick="closeAuth()">✕</div>
            <h2 class="auth-title" id="auth-title">Welcome Back</h2>
            <div class="error-msg" id="auth-error"></div>
            
            <form id="auth-form" onsubmit="handleAuth(event)">
                <input type="text" id="username" class="auth-input" placeholder="Username" style="display: none;">
                <input type="email" id="email" class="auth-input" placeholder="Email Address" required>
                <input type="password" id="password" class="auth-input" placeholder="Password" required>
                <button type="submit" class="btn btn-register" id="auth-submit-btn" style="width: 100%; padding: 15px; font-size: 1.2rem; margin-top: 10px;">Log In</button>
            </form>

            <div class="auth-toggle" id="auth-toggle-text">
                Don't have an account? <span onclick="openAuth('register')">Sign Up</span>
            </div>
        </div>
    </div>

    <script>
        // Failsafe execution: If GSAP fails to load, the page still functions normally
        if (typeof gsap !== 'undefined') {
            gsap.registerPlugin(ScrollTrigger);

            // Hero Init
            gsap.from(".gsap-hero", { opacity: 0, y: 30, duration: 1, stagger: 0.2, ease: "power3.out" });
            
            // Mouse Parallax Effect
            document.addEventListener("mousemove", (e) => {
                const xOffset = (e.clientX / window.innerWidth - 0.5) * 50;
                const yOffset = (e.clientY / window.innerHeight - 0.5) * 50;
                gsap.to(".floating-piece", { 
                    x: xOffset, y: yOffset, duration: 1.5, ease: "power2.out", stagger: 0.05 
                });
            });

            // Scroll Animations
            gsap.utils.toArray('.gsap-fade').forEach(el => {
                gsap.from(el, { scrollTrigger: { trigger: el, start: "top 80%" }, opacity: 0, y: 20, duration: 0.8 });
            });
            
            gsap.from(".gsap-fade-up", { scrollTrigger: { trigger: ".features", start: "top 75%" }, opacity: 0, y: 40, duration: 0.8, stagger: 0.2, ease: "power2.out" });
            gsap.from(".gsap-tech", { scrollTrigger: { trigger: ".tech-grid", start: "top 80%" }, opacity: 0, scale: 0.9, duration: 0.6, stagger: 0.15, ease: "back.out(1.5)" });

            // Stats Counter
            const numberCounter = gsap.utils.toArray('.stat-number')[0];
            gsap.from(numberCounter, {
                scrollTrigger: { trigger: ".stats-banner", start: "top 90%" },
                textContent: 0,
                duration: 2.5,
                ease: "power2.out",
                snap: { textContent: 1 } 
            });
        }

        // --- AUTH LOGIC ---
        let currentMode = 'login';
        
        function openAuth(mode) {
            currentMode = mode;
            document.getElementById('auth-modal').classList.add('active');
            document.getElementById('auth-error').style.display = 'none';
            
            if (mode === 'register') {
                document.getElementById('auth-title').innerText = "Create Account";
                document.getElementById('username').style.display = "block";
                document.getElementById('username').required = true;
                document.getElementById('auth-submit-btn').innerText = "Sign Up";
                document.getElementById('auth-toggle-text').innerHTML = `Already have an account? <span onclick="openAuth('login')">Log In</span>`;
            } else {
                document.getElementById('auth-title').innerText = "Welcome Back";
                document.getElementById('username').style.display = "none";
                document.getElementById('username').required = false;
                document.getElementById('auth-submit-btn').innerText = "Log In";
                document.getElementById('auth-toggle-text').innerHTML = `Don't have an account? <span onclick="openAuth('register')">Sign Up</span>`;
            }
        }

        function closeAuth() { document.getElementById('auth-modal').classList.remove('active'); }

        async function handleAuth(e) {
            e.preventDefault();
            const email = document.getElementById('email').value;
            const password = document.getElementById('password').value;
            const username = document.getElementById('username').value;
            const errorMsg = document.getElementById('auth-error');
            const btn = document.getElementById('auth-submit-btn');

            const endpoint = currentMode === 'login' ? '/api/auth/login' : '/api/auth/register';
            const payload = currentMode === 'login' ? { email, password } : { username, email, password };

            const originalText = btn.innerText;
            btn.innerText = "Processing...";

            try {
                const response = await fetch(endpoint, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });

                const data = await response.json();

                if (data.status === 'success') {
                    window.location.href = '/dashboard';
                } else {
                    errorMsg.innerText = data.message;
                    errorMsg.style.display = 'block';
                    btn.innerText = originalText;
                }
            } catch (err) {
                errorMsg.innerText = "Server error. Try again later.";
                errorMsg.style.display = 'block';
                btn.innerText = originalText;
            }
        }
    </script>
</body>
</html>