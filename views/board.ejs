<body>

<div class="game-wrapper">

  <!-- ═══════════════ LEFT: BOARD AREA ═══════════════ -->
  <div class="board-section">
    
    <!-- Opponent bar (top) -->
    <div class="player-bar">
      <div class="player-identity">
        <div class="player-avatar black">♟</div>
        <div class="player-info">
          <h3 id="black-player-name">Opponent</h3>
          <div class="material-score">
            <span id="captured-by-black" class="captured-pieces"></span>
            <span id="score-black" class="score-diff"></span>
          </div>
        </div>
      </div>
      <div class="clock" id="clock-black">10:00</div>
    </div>

    <!-- Board with coordinate labels -->
    <div class="board-outer">
      <div class="coords-col" id="rank-coords"></div>
      <div class="board-wrap">
        <div class="board" id="board"></div>
        <div class="coords-row" id="file-coords"></div>
      </div>
    </div>

    <!-- Your player bar (bottom) -->
    <div class="player-bar">
      <div class="player-identity">
        <div class="player-avatar white">♙</div>
        <div class="player-info">
          <h3 id="white-player-name"><%= locals.username ? username : 'Guest' %></h3>
          <div class="material-score">
            <span id="captured-by-white" class="captured-pieces"></span>
            <span id="score-white" class="score-diff"></span>
          </div>
        </div>
      </div>
      <div class="clock" id="clock-white">10:00</div>
    </div>
  </div>

  <!-- ═══════════════ RIGHT: SIDE PANEL ═══════════════ -->
  <div class="side-panel">

    <!-- Game status -->
    <div class="status-bar" id="status-bar">
      <div class="status-dot"></div>
      Connecting...
    </div>

    <!-- Move history -->
    <div class="panel-card flex-card moves-card">
      <div class="panel-title" style="display:flex; justify-content:space-between; align-items:center;">
        <span>Moves</span>
        <button id="go-live-btn" class="hidden" onclick="navigateTo(-1)" style="background:var(--green); color:white; border:none; padding:2px 8px; border-radius:4px; cursor:pointer; font-size:0.7rem; font-weight:bold; transition: 0.2s;">
          ● Live
        </button>
      </div>
      <div class="move-list" id="move-list"></div>
      <div class="nav-row">
        <button class="nav-btn" id="btn-first" title="First move">⏮</button>
        <button class="nav-btn" id="btn-prev"  title="Previous">◀</button>
        <button class="nav-btn" id="btn-next"  title="Next">▶</button>
        <button class="nav-btn" id="btn-last"  title="Last move">⏭</button>
      </div>
    </div>

    <!-- Live chat -->
    <div class="panel-card flex-card chat-card">
      <div class="panel-title">Live Chat</div>
      <div id="chat-messages" class="chat-messages">
        <div style="text-align:center; color:var(--text-muted); margin-top:6px; font-size:.8rem;">Room joined. Good luck! 👋</div>
      </div>
      <div class="chat-input-row">
        <input type="text" id="chat-input" placeholder="Say something…" autocomplete="off">
        <button id="btn-send-chat">Send</button>
      </div>
    </div>

    <!-- Resign -->
    <div class="panel-card">
      <div class="btn-row">
        <button class="btn danger" id="btn-resign" style="width:100%;">⚑ &nbsp;Resign</button>
      </div>
    </div>

    <!-- Game over result -->
    <div id="result-card" class="hidden">
      <div class="win-banner" id="win-banner">
        <div class="win-banner-title" id="win-title">White Wins!</div>
        <div class="win-banner-sub"   id="win-sub">by Checkmate</div>
        <button class="btn primary"   id="btn-rematch" style="width:100%; margin-bottom:8px;">Request Rematch</button>
        <button class="btn" onclick="window.location.href='/dashboard'" style="width:100%;">← Dashboard</button>
      </div>
    </div>

  </div>
</div>

<!-- ══════════════ MODALS ══════════════ -->

<!-- Pawn promotion -->
<div class="modal-overlay hidden" id="promo-modal">
  <div class="modal">
    <h3>Promote Pawn</h3>
    <div class="promo-pieces" id="promo-pieces"></div>
  </div>
</div>

<!-- Waiting for opponent -->
<div class="modal-overlay hidden" id="waiting-modal">
  <div class="modal">
    <h2>Waiting for Opponent</h2>
    <p style="color:var(--text-muted); margin:10px 0 6px;">Share this code with a friend:</p>
    <div style="background:var(--bg-inset); padding:12px; border-radius:6px; border:1px solid var(--border); margin-bottom:16px;">
      <div id="room-code-display" style="color:var(--green); font-family:'Roboto Mono',monospace; font-size:1.1rem; letter-spacing:3px; word-break:break-all;"></div>
    </div>
    <button class="btn primary" style="width:100%; margin-bottom:10px;" onclick="copyRoomCode()">Copy Link</button>
    <button class="btn danger"  onclick="window.location.href='/matchmaking'" style="width:100%;">Cancel</button>
  </div>
</div>

<!-- Opponent disconnected -->
<div class="modal-overlay hidden" id="reconnect-modal">
  <div class="modal" style="border-top:4px solid var(--danger);">
    <h2 style="color:var(--danger);">Opponent Disconnected</h2>
    <p style="color:var(--text-muted); margin-top:8px;">Waiting for player to reconnect…</p>
    <div id="reconnect-timer" style="font-family:'Roboto Mono',monospace; font-size:3.5rem; font-weight:700; color:#fff; margin-top:12px;">60</div>
  </div>
</div>

<script>
    const myUsername = "<%= locals.username ? username : 'Guest' %>";

    document.addEventListener("DOMContentLoaded", () => {
        const urlParts = window.location.pathname.split('/');
        const roomCode = urlParts[urlParts.length - 1];
        const displayEl = document.getElementById('room-code-display');
        if (displayEl) displayEl.innerText = roomCode;
    });

    function copyRoomCode() {
        const urlParts = window.location.pathname.split('/');
        const roomCode = urlParts[urlParts.length - 1];
        navigator.clipboard.writeText(window.location.origin + '/play/' + roomCode);
        const btn = event.target;
        btn.innerText = "Link Copied! ✓";
        setTimeout(() => { btn.innerText = "Copy Link"; }, 2000);
    }
</script>

<script src="/public/js/pieces.js"></script>
<script src="/public/js/chess.js"></script>

</body>
</html>
