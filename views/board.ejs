<style>
/* 🔴 DYNAMIC CHECK (The Heartbeat Warning) */
.square.check {
  animation: kingInDanger 1.2s infinite alternate ease-in-out !important;
  z-index: 5;
}

@keyframes kingInDanger {
  0% {
    box-shadow: inset 0 0 15px rgba(239, 68, 68, 0.6), 0 0 10px rgba(239, 68, 68, 0.2);
    background-color: rgba(239, 68, 68, 0.15);
  }
  100% {
    box-shadow: inset 0 0 45px rgba(239, 68, 68, 1), 0 0 25px rgba(239, 68, 68, 0.8);
    background-color: rgba(239, 68, 68, 0.5);
  }
}

/* 💥 CHECKMATE: THE SNIPER IMPACT */
.square.checkmate-flash {
  animation: impactFlash 0.5s ease-out forwards !important;
  z-index: 10;
}

/* The King piece takes the hit (Knockback + Gray out) */
.square.checkmate-flash .piece {
  animation: kingStruck 1s cubic-bezier(0.1, 0.8, 0.2, 1) forwards !important;
  will-change: transform, filter;
  position: relative; /* Required for the crack overlay */
}

/* ⚡ THE INSTANT CRACKS (Inline SVG Overlay) */
.square.checkmate-flash .piece::after {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  /* An aggressive, jagged crack drawn directly in CSS */
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 100 100' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M45,5 L50,30 L30,45 L55,60 L45,95' fill='none' stroke='%23111' stroke-width='3.5' stroke-linecap='round' stroke-linejoin='round'/%3E%3Cpath d='M50,30 L80,25 M55,60 L85,75 M30,45 L10,50' fill='none' stroke='%23111' stroke-width='2.5' stroke-linecap='round'/%3E%3C/svg%3E");
  background-size: cover;
  opacity: 0;
  animation: showCracks 0.6s forwards;
  pointer-events: none;
  z-index: 10;
}

/* 🌪 THE SHARP SCREEN SHAKE */
.board-shake {
  animation: cameraShake 0.6s cubic-bezier(0.36, 0.07, 0.19, 0.97) forwards;
  will-change: transform;
}

@keyframes impactFlash {
  0% { box-shadow: inset 0 0 80px rgba(255, 0, 0, 0.9); background-color: rgba(255, 0, 0, 0.6); }
  100% { box-shadow: inset 0 0 30px rgba(150, 0, 0, 0.8); background-color: rgba(100, 0, 0, 0.4); }
}

@keyframes kingStruck {
  0% { transform: scale(1) rotate(0deg); filter: brightness(1); }
  15% { transform: scale(1.1) rotate(-8deg) translate(-4px, -4px); filter: brightness(2) drop-shadow(0 0 10px white); }
  100% { transform: scale(0.9) rotate(12deg) translate(6px, 8px); filter: grayscale(0.8) brightness(0.7); }
}

@keyframes showCracks {
  0%, 14% { opacity: 0; transform: scale(0.8); }
  15% { opacity: 1; transform: scale(1); filter: drop-shadow(0 0 2px rgba(255,255,255,0.8)); } /* Cracks appear instantly on impact */
  100% { opacity: 0.95; transform: scale(1); filter: drop-shadow(0 0 1px rgba(255,255,255,0.4)); }
}

@keyframes cameraShake {
  0% { transform: translate(0, 0); }
  20% { transform: translate(-8px, 6px); }
  40% { transform: translate(6px, -8px); }
  60% { transform: translate(-4px, 4px); }
  80% { transform: translate(2px, -2px); }
  100% { transform: translate(0, 0); }
}



/* 📱 MOBILE FIX */
@media (max-width: 768px) {
  html, body {
    overflow-x: hidden;
    height: auto;
  }

  .game-wrapper {
    min-height: 100dvh;
  }

  .side-panel {
    overflow: visible;
  }

  #move-list {
    max-height: 200px;
  }
}
</style>
